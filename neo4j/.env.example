# Neo4j Authentication (format: username/password, min 8 chars)
NEO4J_AUTH=neo4j/your-strong-password-here

# Plugins
NEO4J_PLUGINS=["apoc"]

# Memory Configuration (sesuaikan dengan RAM server)
# 2GB server: 256m / 512m / 256m
# 4GB server: 512m / 1G / 512m
# 8GB server: 1G / 2G / 1G
NEO4J_server_memory_heap_initial__size=256m
NEO4J_server_memory_heap_max__size=512m
NEO4J_server_memory_pagecache_size=256m

# APOC Procedures
NEO4J_dbms_security_procedures_unrestricted=apoc.*
